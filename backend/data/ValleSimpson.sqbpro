SELECT e.id, e.nombre_emprendimiento, c.nombre AS categoria
FROM emprendimientos e
JOIN categorias c ON e.categoria_id = c.id
ORDER BY e.nombre_emprendimiento;</sql><current_tab id="0"/></tab_sql></sqlb_project>
